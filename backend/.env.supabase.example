# Environment Variables for Supabase Integration

# Supabase Project URL (from your Supabase dashboard)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (from Project Settings > API)
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (server-side only - from Project Settings > API > service_role)
SUPABASE_SERVICE_KEY=your-service-key-here

# For admin PIN (keep using this for backward compatibility)
ADMIN_PIN=edupath-admin-pin-2025
ADMIN_EMAIL=admin@edupath.ai

# JWT secret for token signing
JWT_SECRET=your-jwt-secret-min-32-chars

# Existing Paystack config
PAYSTACK_SECRET_KEY=your-paystack-secret
PAYSTACK_AMOUNT_KOBO=5000

# Existing OTP salt
OTP_SALT=edupath-otp

# NVIDIA API for AI Advisor
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here