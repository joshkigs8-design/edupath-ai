# ═══ EduPath AI — All Environment Variables ═══
# Add ALL of these to Netlify: Site settings → Environment variables

# ── ADMIN PANEL ───────────────────────────────────────────────────────────────
ADMIN_PIN="edupath-admin-pin-2025"
ADMIN_EMAIL="admin@edupath.ai"

# ── DATABASE (Supabase) ──────────────────────────────────────
# YOUR actual Supabase project URL (pooler port 6543 for Netlify functions)
DATABASE_URL="postgresql://postgres.nucghgwfuivsrvxqjywl:YOUR_SUPABASE_PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET="edupath-kenya-jwt-secret-2025-make-this-longer"

# ── PAYSTACK LIVE KEYS ───────────────────────────────────────
PAYSTACK_SECRET_KEY="YOUR_PAYSTACK_SECRET_KEY"
PAYSTACK_PUBLIC_KEY="YOUR_PAYSTACK_PUBLIC_KEY"
# KES 50 = 5000 kobo (Paystack uses kobo/cents × 100)
PAYSTACK_AMOUNT_KOBO=5000

# ── GMAIL OTP ────────────────────────────────────────────────
GMAIL_USER="your-email@example.com"
GMAIL_APP_PASSWORD="YOUR_GMAIL_APP_PASSWORD"
OTP_SALT="edupath-kenya-2025-otp-salt"

# ── AI (NVIDIA) ──────────────────────────────────────────────
NVIDIA_API_KEY="YOUR_NVIDIA_NIM_API_KEY"

# ── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
FRONTEND_URL="https://your-site.netlify.app"
